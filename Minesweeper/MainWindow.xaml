<Window x:Class="Minesweeper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:UserControls="clr-namespace:Minesweeper.View.UserControls"
        mc:Ignorable="d"
        Title="MainWindow" Height="1000" Width="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{Binding BoardSettingsRowSize}"/>
            <RowDefinition Height="{Binding GameStatsRowSize}"/>
            <RowDefinition Height="8*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>


            <StackPanel Grid.Column="1" Margin="10" VerticalAlignment="Center">
                <TextBlock Text="Number of Rows" FontSize="20"/>
                <TextBox FontSize="20" Text="{Binding Rows}"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="10" VerticalAlignment="Center">
                <TextBlock Text="Number of columns" FontSize="20"/>
                <TextBox FontSize="20" Text="{Binding Columns}"/>
            </StackPanel>
            <StackPanel Grid.Column="3" Margin="10" VerticalAlignment="Center">
                <TextBlock Text="Number of Mines" FontSize="20"/>
                <TextBox FontSize="20" Text="{Binding Mines}"/>
            </StackPanel>
            <Button Grid.Column="4" Height="50" Width="150" Content="Generate Minefield" Command="{Binding GenerateBoardCommand}"/>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>


            <StackPanel Grid.Column="1" Margin="10" VerticalAlignment="Center">
                <TextBlock Text="Mines left" FontSize="20"/>
                <TextBlock FontSize="20" Text="{Binding BoardVM.UnFlaggedMines}"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Margin="10" VerticalAlignment="Center">
                <TextBlock Text="Cells left to reveal" FontSize="20"/>
                <TextBlock FontSize="20" Text="{Binding BoardVM.UnrevealedLocations}"/>
            </StackPanel>
            <Button Grid.Column="3" Height="50" Width="150" Content="Back to settings" Command="{Binding GoBackToSettingsCommand}"/>
        </Grid>


        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <UserControls:BoardView Grid.Row="0" Grid.Column="1" DataContext="{Binding BoardVM}"/>

        </Grid>
    </Grid>
</Window>
